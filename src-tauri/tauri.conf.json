{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "CoinMan Portfolio Tracker",
    "version": "0.5.0",
    "identifier": "com.coinman.portfolio",
    "build": {
        "frontendDist": "../frontend"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.ico",
            "icons/icon.icns"
        ],
        "windows": {
            "nsis": {
                "compression": "lzma",
                "installerIcon": "icons/icon.ico"
            }
        },
        "macOS": {
            "minimumSystemVersion": "10.15",
            "dmg": {
                "background": null,
                "windowSize": { "width": 660, "height": 400 }
            }
        }
    }
}
